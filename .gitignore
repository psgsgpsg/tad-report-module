## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This file is a combination of several sources:
## 1. VisualStudio.gitignore from github.com/github/gitignore
## 2. JetBrains.gitignore from github.com/github/gitignore
## 3. Custom patterns for the TAD Report project

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build Results of an Asset Action
[Aa]ssets.json

# Image fragments
*.tmp

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.bak

# Microsoft Azure Build Output
csx/
*.build.csdef

# Microsoft Azure Cloud Service projects
ecf/
rcf/

# Windows Azure Emulator
vconf/

# Windows Azure Packaging build outputs
*.cscfg
*.csdef
*.ccproj
*.cspkg
*.ctcfg

# Others
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegenerator.cs

# Since we use Directory.Build.props to set artifacts path
artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# AspNet5 build artifacts
bin/
obj/

# ReSharper is a popular Visual Studio add-on
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode
.JustCode

# TeamCity
_TeamCity*

# Olypmus CA UI test Reports
TestResults*

# BOWER
bower_components/

# Node.js
node_modules/
npm-debug.log

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet 4.x+ toolkit
# !.nuget/NuGet.Config
# !.nuget/NuGet.exe
# !.nuget/NuGet.targets

# JetBrains
.idea/
*.iws
out/

# Visual Studio Code
.vscode/
