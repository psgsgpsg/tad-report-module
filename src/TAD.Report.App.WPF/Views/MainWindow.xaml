<Window x:Class="TAD.Report.App.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TAD Test Report"
        Height="600"
        Width="960"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <SolidColorBrush x:Key="AccentBrush" Color="#1E3A8A" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#172554" />
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="28,14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="테스트 리포트 발행"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="#0F172A" />
            <TextBlock Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#64748B"
                       Text="{Binding ReportModel.Title}" />
        </StackPanel>

        <!-- Data -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16"
                                  Direction="270"
                                  Opacity="0.08"
                                  ShadowDepth="2"
                                  Color="#000000" />
            </Border.Effect>
            <DataGrid ItemsSource="{Binding ReportModel.TestCases}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      BorderThickness="0"
                      Background="Transparent"
                      RowHeight="36"
                      FontSize="13"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="#334155" />
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="Background" Value="#F8FAFC" />
                        <Setter Property="BorderBrush" Value="#E2E8F0" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,4" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="번호" Binding="{Binding No}" Width="64" />
                    <DataGridTextColumn Header="테스트 명" Binding="{Binding Name}" Width="*" MinWidth="160" />
                    <DataGridTextColumn Header="결과" Binding="{Binding Result}" Width="88" />
                    <DataGridTextColumn Header="설명" Binding="{Binding Description}" Width="2*" MinWidth="200" />
                    <DataGridTextColumn Header="비고" Binding="{Binding Remarks}" Width="*" MinWidth="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,10"
                       Foreground="#B91C1C"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Text="{Binding ErrorMessage}" />

            <DockPanel Grid.Row="1" LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        Content="PPT 보고서 발행"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ExportReportAsyncCommand}" />
                <TextBlock DockPanel.Dock="Right"
                           Margin="0,0,16,0"
                           VerticalAlignment="Center"
                           Foreground="#64748B"
                           FontSize="13"
                           Text="처리 중…"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </DockPanel>
        </Grid>
    </Grid>
</Window>
